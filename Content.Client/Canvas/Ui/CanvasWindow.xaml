<controls:FancyWindow xmlns="https://spacestation14.io"
                xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                Title="Canvas"
                Resizable="True"
                SetSize="900 700"
                MinSize="800 600">
    <BoxContainer Orientation="Vertical">
        <!-- Header Section -->
        <PanelContainer Name="HeaderPanel">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1e1e1e" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Horizontal" Align="Center" Margin="0 8 0 8">
                <!-- Color Preview with Label -->
                <BoxContainer Orientation="Horizontal" Align="Center" Margin="0 0 16 0">
                    <Label Text="{Loc 'canvas-color-preview'}: " />
                    <Button Name="ColorPreview" MinSize="32 24" MaxSize="32 24" />
                </BoxContainer>
                
                <!-- Paint Code Section -->
                <BoxContainer Orientation="Vertical" Align="Center" MinSize="200 0">
                    <Label Text="{Loc 'canvas-paintcode-label'}" />
                    <LineEdit Name="PaintCodeInput" PlaceHolder="{Loc 'canvas-paintcode'}" HorizontalExpand="True" MinSize="200 0" />
                </BoxContainer>
                
                <!-- Action Buttons -->
                <BoxContainer Orientation="Horizontal" Align="Center" Margin="16 0 0 0" MinSize="0 0">
                    <Button Name="ImportButton" Text="{Loc 'canvas-finalize-import'}" MinSize="100 0" Margin="0 0 8 0" />
                    <Button Name="ExportButton" Text="{Loc 'canvas-export'}" MinSize="80 0" Margin="0 0 8 0" />
                    <Button Name="FinalizeButton" Text="{Loc 'canvas-finalize'}" MinSize="80 0" Margin="0 0 0 0" />
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>
        
        <!-- Separator -->
        <Control MinSize="0 4" />
        
        <!-- Main Content -->
        <BoxContainer Orientation="Horizontal" Align="Begin" VerticalExpand="True">
            <!-- Left Panel: Controls -->
            <PanelContainer Name="LeftPanel">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#2a2a2a" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Vertical" Align="Begin" Margin="12">
                    
                    <!-- Resolution Controls -->
                    <BoxContainer Orientation="Vertical">
                        <Label Text="{Loc 'canvas-resolution'}" />
                        <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                            <Label Text="{Loc 'canvas-height'}: " MinSize="60 0"/>
                            <Slider Name="HeightSize"
                                    MinValue="16"
                                    MaxValue="128"
                                    HorizontalExpand="True"
                                    MinSize="180 0"
                                    Rounded="True" />
                            <Label Name="HeightSizeLabel" Text="16" MinSize="40 0"/>
                        </BoxContainer>
                        <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                            <Label Text="{Loc 'canvas-width'}: " MinSize="60 0"/>
                            <Slider Name="WidthSize"
                                    MinValue="16"
                                    MaxValue="128"
                                    HorizontalExpand="True"
                                    MinSize="180 0"
                                    Rounded="True" />
                            <Label Name="WidthSizeLabel" Text="16" MinSize="40 0"/>
                        </BoxContainer>
                    </BoxContainer>
                    
                    <!-- Separator -->
                    <Control MinSize="0 8" />
                    
                    <!-- Artist Signature -->
                    <BoxContainer Orientation="Vertical">
                        <Label Text="{Loc 'canvas-artist-signature'}" />
                        <LineEdit Name="ArtistSignature" PlaceHolder="{Loc 'canvas-signature'}" HorizontalExpand="True" />
                    </BoxContainer>
                    
                    <!-- Separator -->
                    <Control MinSize="0 8" />
                    
                    <!-- Color Controls -->
                    <BoxContainer Orientation="Vertical">
                        <Label Text="{Loc 'canvas-color-controls'}" />
                        <ColorSelectorSliders Name="ColorSelector" />
                        <BoxContainer Name="ColorSelectorBox" Orientation="Horizontal" Align="Center" Margin="0 8 0 0">
                        </BoxContainer>
                        <!-- Transparency/Eraser Button -->
                        <Button Name="EraserButton" Text="{Loc 'canvas-eraser'}" HorizontalExpand="True" MinSize="0 28" />
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>
            
            <!-- Separator -->
            <Control MinSize="4 0" />
            
            <!-- Right Panel: Drawing Canvas -->
            <PanelContainer>
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#1b1b1e" />
                </PanelContainer.PanelOverride>
                <BoxContainer Name="Grids" Orientation="Vertical" Align="Center" VerticalExpand="True" HorizontalExpand="True">
                    <!-- Add grid content dynamically here -->
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>
        
        <!-- Status Bar -->
        <Control MinSize="0 4" />
        <PanelContainer>
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1e1e1e" />
            </PanelContainer.PanelOverride>
            <Label Name="StatusLabel" Text="{Loc 'canvas-ready'}" Margin="4" />
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
