ghost-role-information-skia-name = Skia.

ghost-role-information-skia-description =  Os destinos cortaram o fio de uma alma, perseguiram as sombras para encontrá-las e colher o que era devido.

ghost-role-information-skia-rules =  Você é um... [color=red][bold]Antagonista Solo[/bold][/color] Você pode matar seu alvo, não precisa garantir que ele permaneça morto, deve evitar atacar os que não são seus, exceto para se proteger ou garantir que seu alvo morra.

skia-role-briefing =  Você é uma esquia, uma sombra da Noösphere, está ligada à escuridão e às sombras, use a escuridão para sua vantagem, encontre sua presa e colha a alma deles, evite acabar com as vidas de inocentes.

skia-round-end-name = Skia.

skia-resurrecting-desc = [color=red]A forma deles muda, parece que estão tentando se reformar![/color]
