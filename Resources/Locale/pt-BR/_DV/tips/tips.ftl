# Tip popup UI strings
tip-popup-okay-button =  Certo.

tip-popup-dont-show-again =  Não mostre isso de novo.

# Example tip content
tip-welcome-title =  Bem-vindo à estação!

tip-welcome-description = Se você é novo, considere pedir ajuda a outros membros da tripulação. [color=yellow][keybind="OpenGuidebook"][/color] para abrir o guia a qualquer momento.

tip-chat-title =  Comunicação

tip-chat-description = Use [color=yellow][keybind="FocusChatInputWindow"][/color] Para conversar local, [color=cyan][keybind="FocusRadioWindow"][/color] para o rádio, e [color=lime]:[/color] Prefixo para canais de departamento.

tip-newplayer-title = Novo Guia do Jogador

tip-newplayer-description =  Parece que você é novo aqui! [color=yellow][keybind="OpenGuidebook"][/color] Para abrir o guia • Use [color=yellow][keybind="ActivateItemInHand"][/color] Para ativar itens na mão [color=yellow][keybind="Drop"][/color] para soltar itens

tip-signlanguage-title =  Língua de Sinais

tip-signlanguage-description =  Você sabe a linguagem de sinais! [color=yellow]J[/color] para abrir o menu radial da linguagem de sinais e comunicar silenciosamente com outros que entendem.

tip-security-title =  Oficial de Segurança.

tip-security-description =  Como oficial de segurança, seu trabalho é [color=yellow] Proteger e servir[/color]  Lembre-se de seguir sempre a lei espacial. [color=red]-S.[/color] para o canal de segurança.

tip-cadet-title =  Cadete de Segurança

tip-cadet-description =  Como novo cadete de segurança, fique perto de seus colegas oficiais e aprenda as cordas. [color=yellow]SOP[/color] e [color=yellow]Lei do Espaço[/color].

tip-medical-title =  Médico Inter

# TODO: If/when we get ProtoData tag that's generic to all prototypes rather than just EntityPrototype, this should be using that for RadioChannelPrototype
tip-medical-description =  Como médico, verifique o [color=cyan]Analisador de saúde[/color]  Seu prefixo de rádio é [color=lightblue]- M.[/color] para o canal médico.

tip-traitor-title =  Agente de Sindicato

tip-traitor-description =  Você é um agente do Sindicato. [color=red]uplink[/color] Complete seus objetivos e não seja pego!

tip-veteran-title =  Obrigado!

tip-veteran-description =  Sua dedicação à estação é apreciada, considere ajudar novos jogadores a aprenderem as cordas.
