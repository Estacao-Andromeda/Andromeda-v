# changestockprice command
cmd-changestocksprice-desc =  Muda o preço de ações da empresa para o número especificado.

cmd-changestocksprice-help = MUDANÇA CONTE <Índice da empresa > Novo preço > [Station UID]

cmd-changestocksprice-invalid-company =  Não executar o comando, o índice da empresa inválida ou o novo preço excede o limite permitido.

cmd-changestocksprice-invalid-station =  Nenhuma bolsa de valores encontrada para estação específica.

cmd-changestocksprice-no-stations =  Nenhuma estação com mercado de ações encontrada.

# addstockscompany command
cmd-addstockscompany-desc =  Adiciona uma nova empresa ao mercado de ações.

cmd-addstockscompany-help = *Addstockscompany <Nome da exibição> <Preço da base> [Station UID]

cmd-addstockscompany-failure =  Não conseguiu adicionar empresa ao mercado de ações.

cmd-addstockscompany-invalid-station =  Nenhuma bolsa de valores encontrada para estação específica.

cmd-addstockscompany-no-stations =  Nenhuma estação com mercado de ações encontrada.
