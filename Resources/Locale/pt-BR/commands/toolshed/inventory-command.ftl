command-description-inventory-getflags =  Todas as entidades em slots na entidade de inventário de tubos combinando com uma certa bandeira de slot.

command-description-inventory-getnamed =  Todas as entidades em slots na entidade de inventários com um nome de slot.

command-description-inventory-forceput =  Coloca uma entidade na primeira entidade que tem um slot que combina com a bandeira, apagando qualquer item anteriormente nesse slot.

command-description-inventory-forcespawn =  Espalha um protótipo na primeira entidade que tem um slot que combina com a bandeira, apagando qualquer item anteriormente naquele slot.

command-description-inventory-put =  Coloca uma entidade na primeira entidade que tem um slot que combina com a bandeira, sem igual qualquer item anteriormente nesse slot.

command-description-inventory-spawn =  Espalha um protótipo na primeira entidade que tem um slot que combina com a bandeira, sem igual qualquer item anteriormente naquele slot.

command-description-inventory-tryput =  Tenta colocar uma entidade na primeira entidade que tem um slot que combina com a bandeira, falhando se algum item estiver nesse slot.

command-description-inventory-tryspawn =  Tenta gerar um protótipo na primeira entidade que tem um slot que combina com a bandeira, falhando se algum item estiver nesse slot.

command-description-inventory-ensure =  Coloca uma entidade na primeira entidade que tem um slot que combina com a bandeira se não existir, passando pelo UID do que estiver no slot até o final.

command-description-inventory-ensurespawn =  Espalha um protótipo na primeira entidade que tem uma fenda que combina com a bandeira, se não existir, passando pelo UID do que estiver na fenda até o final.
