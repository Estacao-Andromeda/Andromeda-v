cmd-quickinspect-desc = Define um nome de componente a ser aberto para uma entidade pairada através do keybind "Inspecionar o servidor/componente do cliente".

cmd-quickinspect-help = Uso: { $command }  Nome do componente

cmd-quickinspect-success =  Componente definido para: { $component } Pressione { $serverKeybind } para abrir uma janela VV para o servidor. { $clientKeybind } para abrir uma janela VV para o cliente.
