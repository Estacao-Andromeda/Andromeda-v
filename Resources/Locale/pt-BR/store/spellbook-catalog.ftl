spellbook-mind-swap-name =  Troca de Mente

spellbook-mind-swap-description = Troque de corpos com outra pessoa!

spellbook-animate-name =  Animar

spellbook-animate-description =  Traga um objeto inanimado para a vida!

spellbook-smite-name = Smite

spellbook-smite-desc =  Não gosta, explicá-los em giblets, requer o Wizard Robe & Hat.

spellbook-cluwne-name = A Maldição de Cluwne

spellbook-cluwne-desc = Para quando você realmente odeia alguém e Smite não é suficiente.

spellbook-slip-name = Slippery Slope

spellbook-slip-desc =  Aprenda os antigos modos do zelador e amaldiçoe seu alvo para ser escorregadio.

spellbook-item-recall-name = Itens de Relembrar

