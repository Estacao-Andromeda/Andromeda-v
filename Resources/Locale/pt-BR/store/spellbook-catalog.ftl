spellbook-repulse-name = Repulsa

spellbook-repulse-desc =  Diga às pessoas para se afastarem de você.

spellbook-smoke-name = Fumaça.

spellbook-smoke-desc =  Chama uma nuvem de fumaça, é bem óbvio.

spellbook-polymorph-spider-name = Aranha Polimorfo

spellbook-polymorph-spider-desc =  Transforma você em uma aranha, cara!

spellbook-polymorph-rod-name = Rod Polymorph

spellbook-polymorph-rod-desc = Transformem-se em um Rod Immovível com movimento limitado.

spellbook-charge-name =  Carregar

spellbook-charge-desc =  Adiciona uma carga de volta à sua varinha!

spellbook-ethereal-jaunt-name = Ethereal Jaunt

