permanent-blindness-trait-examined = [color=lightblue]{ CAPITALIZE(POSS-ADJ($target)) }  Os olhos são vidrados e desfocados. { SUBJECT($target) }  Posso vê-lo bem, se não se importa.[/color]

trait-lightweight-name = Bebida leve.

trait-lightweight-desc = O álcool tem um efeito mais forte em você.

